<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>Add Student</title>
</head>

<body class="bg-slate-900 min-h-screen flex items-center justify-center">

    <div class="bg-slate-800 w-[90%] md:w-[450px] p-8 rounded-3xl shadow-2xl border border-slate-700 text-white">
        <div class="text-center mb-6">
            <h1 class="text-3xl font-bold text-white ">Add Student</h1>
            <p class="text-gray-200 mt-2">
                Create a new student record
            </p>
        </div>

        <% if(success){ %>
            <div class="bg-green-100 border border-green-500 text-green-700 p-3 rounded-lg mb-4">
                <%= success %>
            </div>
        <% } %>

        <form action="/register" method="post" class="space-y-4">
            <div>
                <label class="block mb-2 font-medium text-white">
                    Name
                </label>
                <input
                    class="w-full border border-gray-300 rounded-lg px-4 py-2 outline-none focus:ring-2 focus:ring-blue-500"
                    type="text"
                    name="name"
                    placeholder="Enter Name"
                    required>
            </div>
            <div>
                <label class="block mb-2 font-medium text-white">Nickname</label>
                <input
                    class="w-full border border-gray-300 rounded-lg px-4 py-2 outline-none focus:ring-2 focus:ring-blue-500"
                    type="text"
                    name="nickname"
                    placeholder="Enter Nickname">
            </div>
            <div>
                <label class="block mb-2 font-medium text-white">
                    Score
                </label>
                <input
                    class="w-full border border-gray-300 rounded-lg px-4 py-2 outline-none focus:ring-2 focus:ring-blue-500"
                    type="number"
                    name="score"
                    placeholder="Enter Score">
            </div>
            <button
                type="submit"
                class="w-full bg-blue-400 text-white py-3 rounded-lg font-medium hover:bg-blue-700 transition">
                Create Student
            </button>
        </form>

        <div class="flex justify-between mt-6">
            <a href="/"
                class="bg-gray-600 text-white px-5 py-2 rounded-lg hover:bg-gray-700 transition">
                Home
            </a>
            <a href="/allstudents"
                class="bg-green-600 text-white px-5 py-2 rounded-lg hover:bg-green-700 transition">
                All Students
            </a>
        </div>
    </div>
</body>
</html>