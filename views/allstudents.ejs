<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>All Students</title>
</head>

<body class="bg-gray-100">

    <div class="max-w-5xl mx-auto mt-10">

        <div class="flex justify-between items-center mb-5">
            <h1 class="text-3xl font-bold">All Students</h1>

            <a href="/register" class="bg-blue-600 text-white px-4 py-2 rounded-lg">
                Add Student
            </a>
        </div>

        <div class="bg-white shadow rounded-lg overflow-hidden">

            <table class="w-full text-left">
                <thead class="bg-gray-200">
                    <tr>
                        <th class="p-3">Name</th>
                        <th class="p-3">Nickname</th>
                        <th class="p-3">Score</th>
                        <th class="p-3">Date Of Registration</th>
                        <th class="p-3">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    <% students.forEach(student=> { %>
                        <tr class="border-b">
                            <td class="p-3">
                                <%= student.name %>
                            </td>
                            <td class="p-3">
                                <%= student.nickname %>
                            </td>
                            <td class="p-3">
                                <%= student.score %>
                            </td>
                            <td class="p-3">
                                <%= student.dated.toDateString() %>
                            </td>
                            <td class="p-3 flex gap-2">
                                <a href="/edit/<%= student._id %>"
                                    class="bg-yellow-500 hover:bg-yellow-600 text-white px-3 py-1 rounded-lg">
                                    Edit
                                </a>
                                <form action="/delete/<%= student._id %>" method="POST"
                                    onsubmit="return confirm('Are you sure you want to delete this student?')">
                                    <button type="submit"
                                        class="bg-red-500 hover:bg-red-600 text-white px-3 py-1 rounded-lg">
                                        Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>
        </div>

        <div class="mt-5">
            <a href="/" class="bg-red-500 text-white px-4 py-2 rounded-lg">
                Home
            </a>
        </div>
    </div>
</body>

</html>